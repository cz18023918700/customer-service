# DeepSeek API
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 企业微信配置（拿到后填入）
WECOM_CORP_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_AGENT_ID=

# 服务配置
HOST=0.0.0.0
PORT=8900
DEBUG=true

# 转人工通知（企微群机器人 webhook，可选）
NOTIFY_WEBHOOK=

# 知识库
CHROMA_PERSIST_DIR=./chroma_db
